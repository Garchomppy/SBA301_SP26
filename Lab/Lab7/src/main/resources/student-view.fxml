<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="900.0" prefWidth="1200.0" style="-fx-background-color: #f5f5f5;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ncp.fptu.controllers.StudentController">
   <!-- Header Section -->
   <VBox prefHeight="80.0" prefWidth="1200.0" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
      <Label text="📚 Student Library Management System" textFill="#ffffff" wrapText="true">
         <font>
            <Font name="Segoe UI Bold" size="32.0"/>
         </font>
      </Label>
      <Label text="Manage student information and library records" textFill="#bdc3c7">
         <font>
            <Font name="Segoe UI" size="12.0"/>
         </font>
         <padding>
            <Insets top="5.0"/>
         </padding>
      </Label>
   </VBox>

   <!-- Main Content Section -->
   <HBox layoutY="80.0" prefHeight="820.0" prefWidth="1200.0" spacing="20.0" style="-fx-padding: 20;">
      <!-- Left Panel: Form Section -->
      <VBox prefHeight="800.0" prefWidth="380.0" spacing="15.0"
            style="-fx-border-color: #ecf0f1; -fx-border-radius: 8; -fx-background-color: #ffffff; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
         <Label text="Student Information Form" textFill="#2c3e50">
            <font>
               <Font name="Segoe UI Bold" size="16.0"/>
            </font>
         </Label>

         <Separator style="-fx-padding: 5;"/>

         <!-- Email Field -->
         <VBox spacing="5.0">
            <Label text="📧 Email" textFill="#34495e">
               <font>
                  <Font name="Segoe UI" size="11.0"/>
               </font>
            </Label>
            <TextField fx:id="txtEmail" prefHeight="35.0" promptText="student@example.com"
                       style="-fx-padding: 8; -fx-border-radius: 4; -fx-border-color: #bdc3c7; -fx-font-size: 11;">
               <font>
                  <Font size="11.0"/>
               </font>
            </TextField>
         </VBox>

         <!-- Password Field -->
         <VBox spacing="5.0">
            <Label text="🔒 Password" textFill="#34495e">
               <font>
                  <Font name="Segoe UI" size="11.0"/>
               </font>
            </Label>
            <PasswordField fx:id="txtPassword" prefHeight="35.0" promptText="Enter password"
                           style="-fx-padding: 8; -fx-border-radius: 4; -fx-border-color: #bdc3c7; -fx-font-size: 11;"/>
         </VBox>

         <!-- First Name Field -->
         <VBox spacing="5.0">
            <Label text="👤 First Name" textFill="#34495e">
               <font>
                  <Font name="Segoe UI" size="11.0"/>
               </font>
            </Label>
            <TextField fx:id="txtFirstName" prefHeight="35.0" promptText="John"
                       style="-fx-padding: 8; -fx-border-radius: 4; -fx-border-color: #bdc3c7; -fx-font-size: 11;">
               <font>
                  <Font size="11.0"/>
               </font>
            </TextField>
         </VBox>

         <!-- Last Name Field -->
         <VBox spacing="5.0">
            <Label text="👥 Last Name" textFill="#34495e">
               <font>
                  <Font name="Segoe UI" size="11.0"/>
               </font>
            </Label>
            <TextField fx:id="txtLastName" prefHeight="35.0" promptText="Doe"
                       style="-fx-padding: 8; -fx-border-radius: 4; -fx-border-color: #bdc3c7; -fx-font-size: 11;">
               <font>
                  <Font size="11.0"/>
               </font>
            </TextField>
         </VBox>

         <!-- Marks Field -->
         <VBox spacing="5.0">
            <Label text="⭐ Marks" textFill="#34495e">
               <font>
                  <Font name="Segoe UI" size="11.0"/>
               </font>
            </Label>
            <TextField fx:id="txtMarks" prefHeight="35.0" promptText="0.0"
                       style="-fx-padding: 8; -fx-border-radius: 4; -fx-border-color: #bdc3c7; -fx-font-size: 11;">
               <font>
                  <Font size="11.0"/>
               </font>
            </TextField>
         </VBox>

         <Separator style="-fx-padding: 10;"/>

         <!-- Action Buttons -->
         <HBox spacing="8.0" prefHeight="40.0">
            <Button fx:id="addButton" minWidth="90.0" prefHeight="40.0" onAction="#handleAddStudent"
                    style="-fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 8; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-border-radius: 4; -fx-cursor: hand;"
                    text="➕ Add"/>
            <Button fx:id="updateButton" minWidth="90.0" prefHeight="40.0" onAction="#handleUpdateStudent"
                    style="-fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 8; -fx-background-color: #2980b9; -fx-text-fill: white; -fx-border-radius: 4; -fx-cursor: hand;"
                    text="✏️ Update"/>
            <Button fx:id="deleteButton" minWidth="90.0" prefHeight="40.0" onAction="#handleDeleteStudent"
                    style="-fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 8; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-border-radius: 4; -fx-cursor: hand;"
                    text="🗑️ Delete"/>
         </HBox>

         <Button onAction="#handleClearForm" maxWidth="Infinity" prefHeight="40.0"
                 style="-fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 8; -fx-background-color: #95a5a6; -fx-text-fill: white; -fx-border-radius: 4; -fx-cursor: hand;"
                 text="🔄 Clear Fields"/>

         <!-- Message Label -->
         <Label fx:id="messageLabel" prefHeight="50.0" text=" " textFill="#27ae60" wrapText="true">
            <font>
               <Font name="Segoe UI" size="10.0"/>
            </font>
         </Label>
      </VBox>

      <!-- Right Panel: Search and Table Section -->
      <VBox prefHeight="800.0" prefWidth="780.0" spacing="15.0">
         <!-- Search Section -->
         <VBox spacing="10.0"
               style="-fx-border-color: #ecf0f1; -fx-border-radius: 8; -fx-background-color: #ffffff; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="🔍 Search Student" textFill="#2c3e50">
               <font>
                  <Font name="Segoe UI Bold" size="14.0"/>
               </font>
            </Label>
            <HBox spacing="10.0">
               <TextField fx:id="searchField" prefHeight="35.0" promptText="Search by email..."
                          style="-fx-padding: 8; -fx-border-radius: 4; -fx-border-color: #bdc3c7; -fx-font-size: 11;"
                          HBox.hgrow="ALWAYS">
                  <font>
                     <Font size="11.0"/>
                  </font>
               </TextField>
               <Button fx:id="searchButton" minWidth="120.0" prefHeight="35.0"
                       style="-fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 8; -fx-background-color: #3498db; -fx-text-fill: white; -fx-border-radius: 4; -fx-cursor: hand;"
                       text="🔎 Search"/>
            </HBox>
         </VBox>

         <!-- Table Section -->
         <VBox prefHeight="700.0" prefWidth="780.0" spacing="10.0"
               style="-fx-border-color: #ecf0f1; -fx-border-radius: 8; -fx-background-color: #ffffff; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="👥 Student Records" textFill="#2c3e50">
               <font>
                  <Font name="Segoe UI Bold" size="14.0"/>
               </font>
            </Label>
            <TableView fx:id="studentTable" prefHeight="650.0" prefWidth="750.0"
                       style="-fx-font-size: 11; -fx-font-family: 'Segoe UI';" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="idColumn" minWidth="60.0" prefWidth="80.0" text="ID"/>
                  <TableColumn fx:id="emailColumn" minWidth="150.0" prefWidth="200.0" text="Email"/>
                  <TableColumn fx:id="firstNameColumn" minWidth="100.0" prefWidth="120.0" text="First Name"/>
                  <TableColumn fx:id="lastNameColumn" minWidth="100.0" prefWidth="120.0" text="Last Name"/>
                  <TableColumn fx:id="marksColumn" minWidth="80.0" prefWidth="100.0" text="Marks"/>
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
               </columnResizePolicy>
            </TableView>
         </VBox>
      </VBox>
   </HBox>
</AnchorPane>
